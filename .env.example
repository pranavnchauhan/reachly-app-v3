# ============================================
# Reachly V3 — Environment Variables
# Copy to .env.local and fill in your keys
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Apollo.io — B2B contact enrichment
APOLLO_API_KEY=your-apollo-key

# Perplexity AI — Signal discovery (sonar model)
PERPLEXITY_API_KEY=pplx-your-key

# Firecrawl — Web scraping (optional)
FIRECRAWL_API_KEY=fc-your-key

# Anthropic Claude — Deep research & outreach generation
ANTHROPIC_API_KEY=sk-ant-your-key

# ABR (Australian Business Register) — ABN lookup
# Get from: https://abr.business.gov.au/Tools/WebServices
ABR_API_KEY=your-abr-guid

# Stripe — Credit purchases
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-key
# Webhook signing secret — create endpoint in Stripe Dashboard:
# URL: https://app.reachly.com.au/api/stripe/webhook
# Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_your-key

# Pipeline cron job secret (match this in vercel.json)
CRON_SECRET=your-random-secret

# App URL
NEXT_PUBLIC_APP_URL=https://app.reachly.com.au
# Note: reachly.com.au = marketing website, app.reachly.com.au = this app
